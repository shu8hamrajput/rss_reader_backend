# ── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Google OAuth2 — create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs must include:
#   http://localhost:8000/api/v1/auth/google/callback   (local)
#   https://<your-fly-app>.fly.dev/api/v1/auth/google/callback   (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT — generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# Database (defaults to local SQLite; override for Postgres in production)
# DATABASE_URL=sqlite:///./rss_reader.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ── Production (Fly.io) — set these with `fly secrets set KEY=VALUE` ────────
# fly secrets set GOOGLE_CLIENT_ID=...
# fly secrets set GOOGLE_CLIENT_SECRET=...
# fly secrets set JWT_SECRET_KEY=$(python -c "import secrets; print(secrets.token_hex(32))")
# fly secrets set GOOGLE_REDIRECT_URI=https://<your-app>.fly.dev/api/v1/auth/google/callback
# fly secrets set FRONTEND_URL=https://your-frontend.com
