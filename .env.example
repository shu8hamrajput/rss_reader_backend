# ── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Google OAuth2 — create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs must include:
#   http://localhost:8080/api/v1/auth/google/callback   (local)
#   https://<your-fly-app>.fly.dev/api/v1/auth/google/callback   (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# JWT — generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# Database — PostgreSQL (psycopg3 driver). The docker-compose stack exposes
# Postgres on localhost:5432 with these default credentials.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rss_reader

# Redis — caching, rate limiting, SSE pub/sub, and the Celery result backend
REDIS_URL=redis://localhost:6379/0

# Celery — RabbitMQ broker (task queue) + Redis result backend
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Razorpay — plan-upgrade checkout. Get keys from https://dashboard.razorpay.com/app/keys
# and a webhook secret from Settings → Webhooks (subscribe to `payment.captured`,
# pointed at POST /api/v1/payments/webhook).
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Podcast Index — register free at https://podcastindex.org/apps to get a key.
# Required only for the `podcast_index` search source; all other sources work without a key.
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Anthropic — required only for `--llm` mode of `python -m app.services.parser_gen`.
# Get a key at https://console.anthropic.com/settings/keys. The free heuristic mode
# (no --llm) works without this.
ANTHROPIC_API_KEY=
PARSER_GEN_MODEL=claude-sonnet-4-6

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# ── Production (Fly.io) — set these with `fly secrets set KEY=VALUE` ────────
# fly secrets set GOOGLE_CLIENT_ID=...
# fly secrets set GOOGLE_CLIENT_SECRET=...
# fly secrets set JWT_SECRET_KEY=$(python -c "import secrets; print(secrets.token_hex(32))")
# fly secrets set GOOGLE_REDIRECT_URI=https://<your-app>.fly.dev/api/v1/auth/google/callback
# fly secrets set FRONTEND_URL=https://your-frontend.com
# fly secrets set DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname   (Fly Postgres / Supabase / RDS)
# fly secrets set REDIS_URL=rediss://default:password@host:6379                  (Upstash / Fly Redis)
# fly secrets set CELERY_BROKER_URL=amqps://user:pass@host/vhost                 (CloudAMQP)
# fly secrets set CELERY_RESULT_BACKEND=rediss://default:password@host:6379/1
# fly secrets set RAZORPAY_KEY_ID=rzp_live_...
# fly secrets set RAZORPAY_KEY_SECRET=...
# fly secrets set RAZORPAY_WEBHOOK_SECRET=...
